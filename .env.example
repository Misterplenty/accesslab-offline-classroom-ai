# AccessLab deployment profile.
#   strong -> gemma4:e4b   (stronger laptops, teacher devices, local-hub demos)
#   weak   -> gemma4:e2b   (constrained local profile, proxy-validated only)
# Leave commented to use the strong default.
ACCESSLAB_DEPLOYMENT_PROFILE=strong

# Explicit model override. AccessLab keeps user-facing generation on Gemma 4
# only, so this must stay on one of the supported profile models.
# Useful for benchmarking while still preserving Gemma 4 centrality.
# ACCESSLAB_MODEL=gemma4:e4b

# Current runtime backend. Ollama is the only working backend today.
# `litert-lm-validation` is a non-default scaffold for future validation
# work only; it does not replace the current Ollama path in this repo yet.
# ACCESSLAB_RUNTIME_BACKEND=ollama

# Deployment mode describes how the product is being used locally.
#   single-user-local -> one local user on one local device
#   classroom-local   -> teacher-led classroom use on one device
#   school-box-shared -> one stronger LAN host serving many browsers
# ACCESSLAB_DEPLOYMENT_MODE=single-user-local

# Shared document/session scope for the current deployment.
# ACCESSLAB_CLASS_SPACE=default-classroom

# Conservative queue guardrail for shared use. Leave unset to keep the
# deployment-mode default. In shared mode this acts like a small host-capacity
# budget: upload/index jobs may consume more than one slot so OCR, embeddings,
# and generation do not all pile up blindly under load.
# ACCESSLAB_MAX_CONCURRENT_JOBS=1

# Optional local-only structured capture for future tuning/export work.
#   off -> keep only the normal saved-session history (default)
#   on  -> also store structured QA/code capture records locally for export
# ACCESSLAB_TRAINING_CAPTURE_ENABLED=off

# QA output-discipline profile (revertibility knob).
#   auto    -> follow the deployment profile (weak -> weak, else -> default)
#   default -> always use the validated baseline QA prompt unmodified
#   weak    -> append WEAK_TIER_QA_DISCIPLINE_SUFFIX (one-sentence short answer,
#              inline citations, no bullets) on top of the baseline prompt
# Leave commented for "auto". Set to "default" on a weak install to triage
# the discipline suffix without changing the active model. See
# reports/weak_tier_a11y_discipline_decision_memo.md for the why and the
# measured A/B numbers.
# ACCESSLAB_QA_DISCIPLINE_PROFILE=auto

ACCESSLAB_OLLAMA_URL=http://127.0.0.1:11434

# Optional local semantic retrieval assist.
#   auto -> use local embeddings when available; otherwise fall back to FTS-only
#   off  -> keep retrieval lexical-only
# Leave commented for the default "auto" behavior.
# ACCESSLAB_SEMANTIC_ENABLED=auto

# Local embedding model used by the semantic retrieval assist.
# AccessLab keeps retrieval SQLite-first even when this model is present.
# Default: EmbeddingGemma for local multilingual semantic retrieval.
# ACCESSLAB_SEMANTIC_MODEL=embeddinggemma

# Optional local OCR fallback for scanned / image-based PDFs.
# Leave at "auto" to keep the text-PDF fast path and only OCR pages where
# PyPDF extracts little or no text.
#   auto -> lazy-load OCR extras when a scan-like page is seen
#   on   -> eager-load OCR extras at startup and log missing deps early
#   off  -> disable OCR fallback entirely
# ACCESSLAB_OCR_ENABLED=auto

# Rasterisation DPI for scanned-PDF OCR. Higher values can help faint scans
# but cost more CPU and memory. The app clamps this to [72, 600].
# ACCESSLAB_OCR_DPI=200

# A PDF page whose PyPDF-extracted text falls below this many characters is
# treated as scan-like and routed to OCR fallback.
# ACCESSLAB_OCR_MIN_CHARS_PER_PAGE=20

ACCESSLAB_DATA_DIR=./data
ACCESSLAB_SECRET_KEY=change-me-if-needed
